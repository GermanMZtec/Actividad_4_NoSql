<%- include('../partials/header', { title }) %>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h1 class="h3 mb-1">Películas</h1>
    <p class="text-muted mb-0">Listado completo de películas con géneros resueltos manualmente.</p>
  </div>
  <a class="btn btn-primary" href="/movies/new">Nueva película</a>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Título</th>
          <th>Géneros</th>
          <th>Actores</th>
          <th>Precio</th>
          <th>Creada</th>
          <th class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% movies.forEach((movie) => { %>
          <tr>
            <td class="fw-semibold"><%= movie.title %></td>
            <td><%= movie.genreNames.length ? movie.genreNames.join(', ') : 'Sin géneros' %></td>
            <td>
              <% if (movie.actors.length) { %>
                <% movie.actors.forEach((actor) => { %>
                  <div><%= actor.name %> <span class="text-muted">as</span> <%= actor.character %></div>
                <% }) %>
              <% } else { %>
                <span class="text-muted">Sin actores</span>
              <% } %>
            </td>
            <td>$<%= movie.listPrice.toFixed(2) %></td>
            <td><%= movie.createdAtLabel %></td>
            <td class="text-end">
              <a class="btn btn-sm btn-outline-secondary" href="/movies/edit/<%= movie._id %>">Editar</a>
              <form class="d-inline" action="/movies/delete/<%= movie._id %>" method="post" onsubmit="return confirm('¿Eliminar esta película?')">
                <button class="btn btn-sm btn-outline-danger" type="submit">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (!movies.length) { %>
  <div class="alert alert-info mt-3">No hay películas registradas todavía.</div>
<% } %>

<%- include('../partials/footer') %>