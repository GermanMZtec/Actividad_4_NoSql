<%- include('../partials/header', { title }) %>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h1 class="h3 mb-1">Usuarios</h1>
    <p class="text-muted mb-0">CRUD completo con datos embebidos en el mismo documento.</p>
  </div>
  <a class="btn btn-primary" href="/users/new">Nuevo usuario</a>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Nombre</th>
          <th>Email</th>
          <th>Demografía</th>
          <th>Encuesta</th>
          <th class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((user) => { %>
          <tr>
            <td class="fw-semibold"><%= user.firstName %> <%= user.lastName %></td>
            <td><%= user.email %></td>
            <td>
              <div>Edad: <%= user.demographics.age ?? '-' %></div>
              <div>Educación: <%= user.demographics.education || '-' %></div>
              <div>Ingreso: <%= user.demographics.incomeLevel || '-' %></div>
            </td>
            <td>
              <div>Rating: <%= user.survey.rating ?? '-' %></div>
              <div>Recomienda: <%= user.survey.wouldRecommend ? 'Sí' : 'No' %></div>
            </td>
            <td class="text-end">
              <a class="btn btn-sm btn-outline-secondary" href="/users/edit/<%= user._id %>">Editar</a>
              <form class="d-inline" action="/users/delete/<%= user._id %>" method="post" onsubmit="return confirm('¿Eliminar este usuario?')">
                <button class="btn btn-sm btn-outline-danger" type="submit">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (!users.length) { %>
  <div class="alert alert-info mt-3">No hay usuarios registrados todavía.</div>
<% } %>

<%- include('../partials/footer') %>